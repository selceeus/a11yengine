APP_NAME="A11y Engine"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=a11yengine
DB_USERNAME=postgres
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# -------------------------------------------------------------------
# AI
# -------------------------------------------------------------------
# Provider: openai or anthropic
AI_DRIVER=openai
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Automatically generate an AI audit report on scan completion
AI_AUDIT_AUTO_GENERATE=false

# -------------------------------------------------------------------
# Crawler
# -------------------------------------------------------------------
CRAWLER_SCRIPT_PATH=crawler/scan.js
CRAWLER_TIMEOUT=600
CRAWLER_MAX_PAGES=50
CRAWLER_MAX_DEPTH=5
CRAWLER_PAGE_TIMEOUT_MS=30000
CRAWLER_NAV_TIMEOUT_MS=60000
CRAWLER_REQUEST_DELAY_MS=500
# Verbosity: silent | error | warn | info
CRAWLER_LOG_LEVEL=error

# -------------------------------------------------------------------
# Lighthouse
# -------------------------------------------------------------------
LIGHTHOUSE_BINARY=
LIGHTHOUSE_TIMEOUT=120
LIGHTHOUSE_ENABLED=true
# Path to Chromium executable (optional — leave blank to auto-detect)
LIGHTHOUSE_CHROME_PATH=

# -------------------------------------------------------------------
# Audit tracks (each can be disabled independently)
# -------------------------------------------------------------------
SCREEN_READER_ENABLED=true
CONTENT_ENABLED=true
KEYBOARD_ENABLED=true
INTERACTIVE_ENABLED=true

# -------------------------------------------------------------------
# PDF Scanner (veraPDF REST microservice)
# -------------------------------------------------------------------
PDF_SCANNER_URL=http://pdf-scanner:8080
PDF_SCANNER_TIMEOUT=120
PDF_SCANNER_ENABLED=false

# -------------------------------------------------------------------
# Reverb (WebSockets — real-time scan progress)
# -------------------------------------------------------------------
REVERB_APP_ID=my-app-id
REVERB_APP_KEY=my-app-key
REVERB_APP_SECRET=my-app-secret
REVERB_HOST="localhost"
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# -------------------------------------------------------------------
# Telescope (disable in production)
# -------------------------------------------------------------------
TELESCOPE_ENABLED=true

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"


# PDF Accessibility Scanner
PDF_SCANNER_URL=http://pdf-scanner:8080
PDF_SCANNER_TIMEOUT=120
PDF_SCANNER_ENABLED=false
